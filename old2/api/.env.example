# BoomerItems — Ortam Değişkenleri
# Bu dosyayı .env olarak kopyala ve değerleri doldur
# .env dosyasını asla Git'e commit etme!

# ── Veritabanı ───────────────────────────────
DB_HOST=localhost
DB_NAME=boomeritems
DB_USER=root
DB_PASS=
DB_CHARSET=utf8mb4

# ── JWT ──────────────────────────────────────
# En az 64 karakter, rastgele üret:
# php -r "echo bin2hex(random_bytes(32));"
JWT_SECRET=buraya_en_az_64_karakter_rastgele_bir_deger_yaz
JWT_EXPIRE=604800

# ── Uygulama ─────────────────────────────────
APP_ENV=production
APP_URL=https://boomeritems.com
ALLOWED_ORIGIN=https://boomeritems.com

# ── Upload ───────────────────────────────────
UPLOAD_DIR=../public/uploads
UPLOAD_MAX_MB=5

# ── Rate Limiting ─────────────────────────────
RATE_LIMIT_LOGIN=5
RATE_LIMIT_WINDOW=300

# ── Email (KAPALI — aktif etmek için true yap) ─
MAIL_ENABLED=false
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_SECURE=tls
MAIL_USER=your-gmail@gmail.com
MAIL_PASS=your-app-password
MAIL_FROM_EMAIL=noreply@boomeritems.com
MAIL_FROM_NAME=BoomerItems

# ── Loglama ──────────────────────────────────
LOG_ENABLED=true
LOG_DIR=./logs
